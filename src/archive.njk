---
layout: layouts/base.njk
title: 归档
permalink: /archive/
---
<div class="section-label">文章归档 · 共 {{ collections.posts.length }} 篇</div>

{% for group in collections.postsByYearMonth %}
  <div class="arc-year">
    <h2 class="arc-year-title">{{ group.year }} 年</h2>
    {% for m in group.months %}
      <div class="arc-month">
        <div class="arc-month-title">{{ m.monthCn }}</div>
        {% for post in m.posts %}
          <a class="arc-art" href="{{ post.url }}">
            <span class="arc-d">{{ post.date.getDate() }}日</span>
            <span class="arc-t">{{ post.data.title or post.page.fileSlug }}</span>
            {% if post.data.tags and post.data.tags.length %}
              <span class="arc-tags">
                {% for tag in post.data.tags %}
                  <span class="arc-tag">{{ tag }}</span>
                {% endfor %}
              </span>
            {% endif %}
          </a>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
{% endfor %}
