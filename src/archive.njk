---
layout: layouts/base.njk
title: 归档
permalink: /archive/
---
<section class="posts-section">
  <h2>归档</h2>
  <p class="archive-meta">共 {{ collections.posts.length }} 篇文章</p>

  {% for group in collections.postsByYear %}
    <div class="archive-year">
      <h3 class="archive-year-title">{{ group.year }}</h3>
      <ul class="archive-list">
        {% for post in group.posts %}
          <li class="archive-item">
            <time datetime="{{ post.date | htmlDateString }}">{{ post.date | htmlDateString }}</time>
            <a href="{{ post.url }}">{{ post.data.title or post.page.fileSlug }}</a>
          </li>
        {% endfor %}
      </ul>
    </div>
  {% endfor %}
</section>
