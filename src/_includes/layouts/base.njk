<!DOCTYPE html>
<html lang="{{ site.language }}">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;500&family=ZCOOL+XiaoWei&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link rel="alternate" type="application/rss+xml" title="{{ site.title }} RSS" href="/feed.xml" />
    <script>
      // Apply theme preference early to avoid flash of wrong theme.
      // Three-theme cycle: paper (default) → modern → midnight.
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          var valid = ["paper", "modern", "midnight"];
          var theme = valid.indexOf(stored) !== -1 ? stored : "paper";
          document.body && document.body.setAttribute("data-theme", theme);
          // body may not exist yet — fallback via documentElement, re-apply on DOMContentLoaded.
          document.documentElement.setAttribute("data-theme", theme);
          document.addEventListener("DOMContentLoaded", function () {
            document.body.setAttribute("data-theme", theme);
          });
        } catch (e) {}
      })();
    </script>
  </head>
  <body data-theme="paper">
    <div id="readingProgress" class="read-prog" hidden></div>

    <nav class="nav">
      <div class="nav-inner">
        <a class="nav-title" href="/">{{ site.title }}</a>
        <div class="nav-links">
          <a href="/" class="nav-link{% if page.url == '/' %} active{% endif %}">首页</a>
          <a href="/about/" class="nav-link{% if '/about/' in page.url %} active{% endif %}">关于</a>
          <a href="/archive/" class="nav-link{% if '/archive/' in page.url %} active{% endif %}">归档</a>
          <button
            type="button"
            id="themeToggle"
            class="icon-btn"
            aria-label="切换主题"
            title="切换主题（纸 / 摩登 / 午夜）"
          >
            <span id="themeIcon" aria-hidden="true">☀</span>
          </button>
        </div>
      </div>
    </nav>

    <main id="pjax-root" class="main page-enter">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <p>{{ site.title }} · 由 Eleventy 渲染 · Giscus 评论</p>
      <p class="footer-ornament">·&nbsp;·&nbsp;·&nbsp;·&nbsp;·</p>
    </footer>

    <button type="button" id="backToTop" class="btt hidden" aria-label="回到顶部" title="回到顶部">↑</button>

    <script src="/assets/js/site.js" defer></script>
  </body>
</html>
